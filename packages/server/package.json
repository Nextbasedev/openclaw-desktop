{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "pnpm --filter middleware build && tsx watch src/index.ts",
    "build": "pnpm --filter middleware build && tsc",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --forceExit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^5.1.0",
    "middleware": "workspace:*",
    "node-pty": "^1.1.0",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}
