{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw",
  "version": "0.1.0",
  "identifier": "ai.openclaw.jarvis",
  "build": {
    "frontendDist": "../../ui/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --dir ../.. dev:local",
    "beforeBuildCommand": "node ../../scripts/prepare-tauri-bundle.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "bundled/middleware/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3RUMzNzM1MkFFNjA5MEUKUldRT0NlWXFOVGZzbDB4RXExQXlYRFpUSTNpb1pXUXFUSXdjOUw0cnVoSFRBeUJySjVYZE1BS24K",
      "endpoints": [
        "https://github.com/Nextbasedev/openclaw-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
