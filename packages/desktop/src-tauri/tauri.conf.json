{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw",
  "version": "0.1.0",
  "identifier": "ai.openclaw.jarvis",
  "build": {
    "frontendDist": "../../ui/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --dir ../.. dev:local",
    "beforeBuildCommand": "node ../../scripts/prepare-tauri-bundle.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bundled/middleware/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
